<section id="testimonials" class="bg-gray-50 py-16">
  <div class="relative overflow-hidden">
    <!-- Heading -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-4"><?php echo get_field('slider_title'); ?></h2>
      <p class="text-gray-600 text-lg max-w-2xl mx-auto">
        <?php echo get_field('slider_subheading'); ?>
      
    </div>
<!-- Slider Track -->
<div id="testimonialSlider" class="flex transition-transform duration-500 ease-in-out">

  <?php
  $args = array(
    'post_type' => 'testimonial',
    'posts_per_page' => -1
  );

  $loop = new WP_Query($args);

  if ($loop->have_posts()):
    while ($loop->have_posts()): $loop->the_post();
  ?>

    <div class="w-full flex-shrink-0 bg-white rounded-xl shadow-lg p-6 flex flex-col items-center text-center">

      <?php if (get_field('testimonial_image')): ?>
        <img src="<?php the_field('testimonial_image'); ?>" 
             alt="<?php the_field('testimonial_author'); ?>" 
             class="w-16 h-16 rounded-full mb-4 object-cover">
      <?php endif; ?>

      <p class="text-gray-700">“<?php the_field('testimonial_text'); ?>”</p>

      <span class="mt-3 text-sm font-semibold text-gray-900">
        — <?php the_field('testimonial_author'); ?>, <?php the_field('testimonial_location'); ?>
      </span>

    </div>

  <?php
    endwhile;
  endif;
  wp_reset_postdata();
  ?>

</div>

<div id="testimonialDots" class="flex justify-center mt-6 space-x-2">
<?php
$testimonial_count = wp_count_posts('testimonial')->publish;
for ($i = 0; $i < $testimonial_count; $i++):
?>
    <span class="testimonial-dot w-3 h-3 rounded-full <?php echo $i === 0 ? 'bg-gray-400' : 'bg-gray-300'; ?> cursor-pointer"></span>
<?php endfor; ?>

</div>
</div>
</section>